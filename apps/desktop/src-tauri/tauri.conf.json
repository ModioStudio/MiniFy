{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniFy",
  "version": "0.1.0",
  "identifier": "com.modiostudio.minify",

  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node src-tauri/scripts/inject-pubkey.js && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "MiniFy",
        "decorations": false,
        "minWidth": 400,
        "minHeight": 200,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": false,
        "scope": ["https://*.spotify.com/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGMzVDRDRGQ0UyRTdEMTgKUldRWWZTN09UODAxZnpvemRYYXc1TTJycERLR3F5cVZXNHBuZ0lTeGpXdXlhR3Ivbjh0ZXNETCsK",
      "endpoints": [
        "https://github.com/ModioStudio/MiniFy/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
