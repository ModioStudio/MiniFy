{
  "name": "MiniFy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:oxlint": "oxlint . --ignore-path .gitignore --ignore-pattern apps/desktop/src-tauri/gen/** --ignore-pattern apps/www/components/ui/** --ignore-pattern apps/www/styles/**",
    "quality": "pnpm lint:oxlint",
    "test": "pnpm quality",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "desktop:dev": "pnpm --filter desktop tauri dev",
    "desktop:build": "pnpm --filter desktop build",
    "desktop:clear-auth": "pnpm --filter desktop clear-auth",
    "desktop:clear": "pnpm --filter desktop clear-auth",
    "www:dev": "pnpm --filter www dev",
    "www:build": "pnpm --filter www build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@turbo/gen": "^2.10.3",
    "oxlint": "^1.72.0",
    "turbo": "^2.10.3"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20.19.0"
  }
}
