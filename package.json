{
  "name": "MiniFy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "desktop:dev": "pnpm --filter desktop tauri dev",
    "desktop:build": "pnpm --filter desktop build",
    "desktop:clear-auth": "pnpm --filter desktop clear-auth",
    "desktop:clear": "pnpm --filter desktop clear-auth",
    "desktop:cef:setup": "pnpm --filter desktop cef:setup",
    "desktop:cef:cleanup": "pnpm --filter desktop cef:cleanup",
    "desktop:dev:cef": "pnpm --filter desktop dev:cef",
    "desktop:build:cef": "pnpm --filter desktop build:cef",
    "desktop:build:cef:release": "pnpm --filter desktop build:cef:release",
    "desktop:build:cef:nsis": "pnpm --filter desktop build:cef:nsis",
    "desktop:build:cef:deb": "pnpm --filter desktop build:cef:deb",
    "www:dev": "pnpm --filter www dev",
    "www:build": "pnpm --filter www build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@changesets/cli": "^2.28.1",
    "@turbo/gen": "^2.7.2",
    "lefthook": "^2.0.13",
    "turbo": "^2.7.2"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=18"
  }
}
